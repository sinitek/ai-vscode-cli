{
  "name": "sinitek-cli-tools",
  "displayName": "携宁 CLI 助手",
  "description": "VS Code extension to run Codex, Claude, and Gemini CLI tools.",
  "version": "0.0.4",
  "publisher": "sinitek",
  "repository": {
    "type": "git",
    "url": "https://codeup.aliyun.com/62491de354d036291ae14d9c/vscode/sinitek_cli.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:sinitek-cli-tools.selectCli",
    "onCommand:sinitek-cli-tools.runCli",
    "onCommand:sinitek-cli-tools.runCliThinkingOn",
    "onCommand:sinitek-cli-tools.runCliThinkingOff",
    "onCommand:sinitek-cli-tools.openPanel",
    "onView:sinitek-cli-tools.panelView",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sinitek-cli-tools.selectCli",
        "title": "CLI Bridge: Select CLI"
      },
      {
        "command": "sinitek-cli-tools.runCli",
        "title": "CLI Bridge: Run Current CLI"
      },
      {
        "command": "sinitek-cli-tools.runCliThinkingOn",
        "title": "CLI Bridge: Run Current CLI (Thinking On)"
      },
      {
        "command": "sinitek-cli-tools.runCliThinkingOff",
        "title": "CLI Bridge: Run Current CLI (Thinking Off)"
      },
      {
        "command": "sinitek-cli-tools.openPanel",
        "title": "CLI Bridge: Open Panel"
      }
    ],
    "configuration": {
      "title": "CLI Bridge",
      "properties": {
        "sinitek-cli-tools.defaultCli": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "gemini"
          ],
          "default": "codex",
          "description": "Default CLI to run when the extension activates."
        },
        "sinitek-cli-tools.commands.codex": {
          "type": "string",
          "default": "codex",
          "description": "Command used to run Codex CLI."
        },
        "sinitek-cli-tools.commands.claude": {
          "type": "string",
          "default": "claude",
          "description": "Command used to run Claude CLI."
        },
        "sinitek-cli-tools.commands.gemini": {
          "type": "string",
          "default": "gemini",
          "description": "Command used to run Gemini CLI."
        },
        "sinitek-cli-tools.args.codex": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--dangerously-bypass-approvals-and-sandbox",
            "--sandbox",
            "danger-full-access",
            "--enable",
            "web_search_request"
          ],
          "description": "Default arguments for Codex CLI."
        },
        "sinitek-cli-tools.args.claude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--dangerously-skip-permissions"
          ],
          "description": "Default arguments for Claude CLI."
        },
        "sinitek-cli-tools.args.gemini": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-y"
          ],
          "description": "Default arguments for Gemini CLI."
        },
        "sinitek-cli-tools.autoOpenPanel": {
          "type": "boolean",
          "default": true,
          "description": "Open the CLI Bridge panel automatically on activation."
        },
        "sinitek-cli-tools.rememberSelectedCli": {
          "type": "boolean",
          "default": true,
          "description": "Persist the selected CLI as the default CLI."
        },
        "sinitek-cli-tools.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for CLI stdin/stdout/stderr."
        },
        "sinitek-cli-tools.interactive.codex": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable interactive (persistent) mode for Codex (Beta)."
        },
        "sinitek-cli-tools.interactive.claude": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable interactive (persistent) mode for Claude (Beta)."
        },
        "sinitek-cli-tools.disableMarketplaceUpdateCheckInDev": {
          "type": "boolean",
          "default": true,
          "description": "Disable VS Code marketplace update checks while running this extension in development mode."
        },
        "sinitek-cli-tools.thinkingMode": {
          "type": "string",
          "enum": [
            "off",
            "low",
            "medium",
            "high"
          ],
          "default": "medium",
          "description": "Global thinking mode for all CLIs."
        },
        "sinitek-cli-tools.thinkingModeCodex": {
          "type": "string",
          "enum": [
            "on",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
