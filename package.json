{
  "name": "sinitek-cli-tools",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.5.0",
  "publisher": "Sinitek",
  "repository": {
    "type": "git",
    "url": "https://codeup.aliyun.com/62491de354d036291ae14d9c/vscode/sinitek_cli.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:sinitek-cli-tools.selectCli",
    "onCommand:sinitek-cli-tools.runCli",
    "onCommand:sinitek-cli-tools.runCliThinkingOn",
    "onCommand:sinitek-cli-tools.runCliThinkingOff",
    "onCommand:sinitek-cli-tools.openPanel",
    "onView:sinitek-cli-tools.panelView",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sinitek-cli-tools.selectCli",
        "title": "%command.selectCli%"
      },
      {
        "command": "sinitek-cli-tools.runCli",
        "title": "%command.runCli%"
      },
      {
        "command": "sinitek-cli-tools.runCliThinkingOn",
        "title": "%command.runCliThinkingOn%"
      },
      {
        "command": "sinitek-cli-tools.runCliThinkingOff",
        "title": "%command.runCliThinkingOff%"
      },
      {
        "command": "sinitek-cli-tools.openPanel",
        "title": "%command.openPanel%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "sinitek-cli-tools.defaultCli": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "gemini"
          ],
          "default": "codex",
          "description": "%config.defaultCli.description%"
        },
        "sinitek-cli-tools.commands.codex": {
          "type": "string",
          "default": "codex",
          "description": "%config.commands.codex.description%"
        },
        "sinitek-cli-tools.commands.claude": {
          "type": "string",
          "default": "claude",
          "description": "%config.commands.claude.description%"
        },
        "sinitek-cli-tools.commands.gemini": {
          "type": "string",
          "default": "gemini",
          "description": "%config.commands.gemini.description%"
        },
        "sinitek-cli-tools.args.codex": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--dangerously-bypass-approvals-and-sandbox",
            "--sandbox",
            "danger-full-access",
            "--enable",
            "web_search_request"
          ],
          "description": "%config.args.codex.description%"
        },
        "sinitek-cli-tools.args.claude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--dangerously-skip-permissions"
          ],
          "description": "%config.args.claude.description%"
        },
        "sinitek-cli-tools.args.gemini": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-y"
          ],
          "description": "%config.args.gemini.description%"
        },
        "sinitek-cli-tools.autoOpenPanel": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoOpenPanel.description%"
        },
        "sinitek-cli-tools.rememberSelectedCli": {
          "type": "boolean",
          "default": true,
          "description": "%config.rememberSelectedCli.description%"
        },
        "sinitek-cli-tools.debug": {
          "type": "boolean",
          "default": false,
          "description": "%config.debug.description%"
        },
        "sinitek-cli-tools.locale": {
          "type": "string",
          "enum": [
            "auto",
            "zh-CN",
            "en"
          ],
          "default": "auto",
          "description": "%config.locale.description%"
        },
        "sinitek-cli-tools.macTaskShell": {
          "type": "string",
          "enum": [
            "zsh",
            "bash"
          ],
          "default": "zsh",
          "description": "%config.macTaskShell.description%"
        },
        "sinitek-cli-tools.disableMarketplaceUpdateCheckInDev": {
          "type": "boolean",
          "default": true,
          "description": "%config.disableMarketplaceUpdateCheckInDev.description%"
        },
        "sinitek-cli-tools.thinkingMode": {
          "type": "string",
          "enum": [
            "off",
            "low",
            "medium",
            "high"
          ],
          "default": "medium",
          "description": "%config.thinkingMode.description%"
        },
        "sinitek-cli-tools.thinkingModeCodex": {
          "type": "string",
          "enum": [
            "on",
            "low",
            "medium",
            "high",
            "xhigh"
